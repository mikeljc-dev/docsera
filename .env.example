# ─── Base de datos ───────────────────────────────────────────
# Postgres con la extension pgvector
DATABASE_URL=postgresql://askdocs:askdocs@localhost:5432/askdocs

# Dimensiones del vector de embeddings, fijas en la columna `chunks.embedding`.
# Debe coincidir con el modelo de embeddings que uses (ej: 1536 para
# text-embedding-3-small de OpenAI). Si la cambias tras la primera ingesta,
# necesitas re-ingestar todo (o una nueva migracion que recree la columna).
EMBEDDING_DIMENSIONS=1536

# ─── Proveedor de LLM ────────────────────────────────────────
# Opciones: anthropic | openai | ollama
LLM_PROVIDER=anthropic

# Rellena solo la del proveedor que uses.
# En modo self-hosted, estas keys son las del cliente y no salen de su servidor.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Para Ollama (modelos locales), URL del servidor Ollama
OLLAMA_BASE_URL=http://localhost:11434

# ─── Servidor ────────────────────────────────────────────────
PORT=3000

# Origenes permitidos para el widget (CORS), separados por coma
# Ej: https://midominio.com,https://docs.midominio.com
ALLOWED_ORIGINS=http://localhost:5173
