# ─── Base de datos ───────────────────────────────────────────
# Postgres con la extension pgvector
DATABASE_URL=postgresql://docsera:docsera@localhost:5432/docsera

# Dimensiones del vector de embeddings, fijas en la columna `chunks.embedding`.
# Debe coincidir EXACTAMENTE con el modelo de embeddings que uses (ej: 1536
# para text-embedding-3-small de OpenAI, 768 para nomic-embed-text de Ollama).
# Si la cambias tras la primera ingesta, necesitas re-ingestar todo (o una
# nueva migracion que recree la columna).
EMBEDDING_DIMENSIONS=1536

# ─── Proveedor de LLM (chat) ──────────────────────────────────
# Opciones: anthropic | openai | ollama
LLM_PROVIDER=anthropic
# Modelo a usar por el proveedor de chat. Opcional: cada adaptador tiene un
# default razonable (ver packages/server/src/llm/*.ts).
LLM_MODEL=

# ─── Proveedor de embeddings (ingesta) ────────────────────────
# Opciones: openai | ollama (Anthropic no tiene API de embeddings, por eso
# no es una opcion aqui aunque sea tu LLM_PROVIDER para el chat).
EMBEDDING_PROVIDER=openai
# Modelo de embeddings. Opcional: cada adaptador tiene un default razonable.
EMBEDDING_MODEL=

# Rellena solo las keys/URLs de los proveedores que uses arriba.
# En modo self-hosted, estas keys son las del cliente y no salen de su servidor.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# URL base para el adaptador "openai": dejala vacia para la API de OpenAI, o
# apunta a cualquier API compatible (Gemini en modo compatibilidad, Groq,
# Mistral, LM Studio, vLLM...). La key sigue siendo OPENAI_API_KEY.
# Ej Gemini (free tier): https://generativelanguage.googleapis.com/v1beta/openai
OPENAI_BASE_URL=

# Para Ollama (modelos locales), URL del servidor Ollama
OLLAMA_BASE_URL=http://localhost:11434

# ─── Servidor ────────────────────────────────────────────────
PORT=3000

# Origenes permitidos para el widget (CORS), separados por coma
# Ej: https://midominio.com,https://docs.midominio.com
ALLOWED_ORIGINS=http://localhost:5173

# Token secreto para autenticar endpoints de administracion (ej: POST
# /ingest). Genera uno con: openssl rand -hex 32
ADMIN_TOKEN=

# Limite de peticiones a POST /chat por IP y por minuto (endpoint publico,
# usado por el widget). Proteccion basica de coste, no distribuida.
CHAT_RATE_LIMIT=20

# Topes diarios opcionales (0 = desactivado), pensados para demos publicas:
# por IP y global de toda la instancia. Acotan el gasto total de LLM aunque
# el limite por minuto no pare a un abusador paciente o distribuido.
CHAT_DAILY_LIMIT=0
CHAT_GLOBAL_DAILY_LIMIT=0

# Frase que ve el usuario cuando la documentacion no contiene la respuesta.
# Ponla en el idioma de tus usuarios. Default: "I don't know."
# (La deteccion interna no depende de esta frase: el LLM devuelve un
# centinela NO_ANSWER y el server lo sustituye por esta frase.)
CHAT_NO_ANSWER_TEXT=

# Distancia coseno maxima (0 = identico, 2 = opuesto) para que un chunk se
# considere relevante en la recuperacion. Si ningun chunk pasa el umbral, el
# server responde "No lo se" sin llamar al LLM (ahorro de coste). El valor
# util depende del modelo de embeddings: sube el umbral si ves demasiados
# "No lo se", bajalo si cuela contexto irrelevante. 2 desactiva el filtro.
CHAT_MAX_DISTANCE=0.8

# Pon "true" SOLO si el server esta detras de un reverse proxy tuyo (nginx,
# Caddy, Traefik...) que sobreescriba x-forwarded-for. Con "true", el rate
# limit usa esa cabecera como IP del cliente; si el server esta expuesto
# directamente, dejalo en false o cualquiera podria falsificarla para
# saltarse el limite.
TRUST_PROXY=false
