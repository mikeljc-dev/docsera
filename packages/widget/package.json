{
  "name": "@docsera/widget",
  "version": "0.6.0",
  "private": true,
  "description": "Web component embebible del chat Docsera",
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "esbuild src/entry.ts --bundle --format=iife --outfile=public/widget.js --watch --servedir=public",
    "build": "esbuild src/entry.ts --bundle --format=iife --outfile=dist/widget.js --minify",
    "lint": "eslint src",
    "test": "tsx --test $(find src -name '*.test.ts')",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "lit": "^3.3.3"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.23.1"
  }
}
