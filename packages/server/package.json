{
  "name": "@docsera/server",
  "version": "0.5.0",
  "private": true,
  "description": "API de Docsera: chat (RAG), ingesta y administracion",
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json && node -e \"require('fs').cpSync('src/db/migrations','dist/db/migrations',{recursive:true})\"",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test $(find src -name '*.test.ts')",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.10",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.2",
    "hono": "^4.12.30",
    "pg": "^8.22.0",
    "unpdf": "1.6.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.23.1"
  }
}
